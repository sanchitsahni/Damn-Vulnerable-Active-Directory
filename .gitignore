# ==============================================================================
# DVAD - Deployable Vulnerable Active Directory
# ==============================================================================

# --- Generated VM artifacts (anchored to repo root) ---
.commandcode/
/vms/
*.qcow2
*.qcow2.tmp
*.pid
*.mon
*.installed
*.log
.gitignore 
CLAUDE.md
PLAN.md
PRD.md
vulnerability_report.csv
.antigravitycli/

# --- Windows install media (very large; download via deploy.sh) ---
/media/
*.iso
*.img
virtio-win-*.iso

# --- Per-VM unattend XML + post-install scripts (generated by vm-create.sh) ---
# Anchor to repo root so windows/autounattend/ (a source template) isn't hidden.
/autounattend/
!/autounattend/.gitkeep

# --- /tmp dnsmasq runtime state (path is absolute; kept for grep-ability) ---
/tmp/dvad-*
dnsmasq.leases
dnsmasq.log
dnsmasq.pid

# --- Ansible runtime artifacts ---
ansible/*.retry
ansible/*.log
ansible/.vault_pass
ansible/inventory.local.yml
*.retry

# --- Python / virtualenv ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.python-version

# --- Editor / OS noise ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Stale tool state (see CLAUDE.md - .nanocoder/tasks.json is unreliable) ---
.nanocoder/

# ==============================================================================
# AI coding-agent artifacts (Claude Code / Claude Agent SDK / similar)
# These are local state for the agent driving the repo — never useful to ship
# to end users. Keep CLAUDE.md and AGENTS.md tracked (they're orientation docs),
# but ignore every runtime / scratch file the agent writes.
# ==============================================================================
# Claude Code project-local state, settings, hooks, transcripts
.claude/
.claude-*/
.anthropic/
.claude-profiles/
.claude-code/
.claude.json
.claude.local.json
.claude/settings.local.json
.claude/hooks/
.claude/commands/
.claude/agents/
.claude/skills/
.claude/scheduled_tasks.json
.claude/worktrees/
.claude/plans/
.claude/memory/
.claude/sessions/
.claude/transcripts/
.claude/cache/
.claude/tmp/

# Claude-generated planning / memory / scratch files (live at repo root)
PLAN.md.local
MEMORY.md
memory/
plans/
.plan/
.memory/
.scratch/
scratch/
notes.local.md
TODO.local.md

# Worktrees the agent creates for isolated work
worktrees/
.worktrees/

# Other agentic coding tools (ignore if present — none are shipped)
.aider*
.cursor/
.continue/
.windsurf/
.copilot/
.cody/
.codeium/
.tabnine/
.codestral/
.zed/
.sourcegraph/

# JSONL transcripts / agent run logs (anywhere in tree)
*.jsonl
*.agent.log
*.session.log
*.claude.log

# ==============================================================================

# --- Local secrets / overrides (never commit) ---
*.local.yml
*.local.sh
secrets/
*.key
*.pem
*.pfx
!**/test-fixtures/**/*.pem
!**/test-fixtures/**/*.key

# --- Build / handout output ---
out/
build/
dist/
handout/

# --- Lab flags generated at runtime by flag_factory ---
flags/output/
flags/*.generated.json

# --- Backup files ---
*.bak
*.orig
*.tmp

# --- Reports ---
vulnerability_report*.csv

vulnerability_report.csv
missing_checks.json

# --- AI Agent State ---
.antigravitycli/
